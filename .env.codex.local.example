# Copy the values you need into .env.local or .env.codex.local.
# Keep real secrets out of git.

CODEX_BRIDGE_HOST=127.0.0.1
CODEX_BRIDGE_PORT=4186
CODEX_PUBLIC_ORIGIN=https://linker.dialtone.earth

# Optional Cloudflare tunnel settings.
CODEX_TUNNEL_NAME=codex
CODEX_TUNNEL_TOKEN=
CODEX_CLOUDFLARED_BIN=

# Optional browser override for direct bridge mode during local development.
VITE_CODEX_BRIDGE_URL=http://127.0.0.1:4186
